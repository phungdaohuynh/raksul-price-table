{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@raksul-price-table/api": ["packages/api/src/index.ts"],
      "@raksul-price-table/api/*": ["packages/api/src/*"],
      "@raksul-price-table/shared": ["packages/shared/src/index.ts"],
      "@raksul-price-table/shared/*": ["packages/shared/src/*"],
      "@raksul-price-table/ui": ["packages/ui/src/index.ts"],
      "@raksul-price-table/ui/*": ["packages/ui/src/*"]
    }
  }
}
